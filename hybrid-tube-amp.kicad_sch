	(text "Auxiliary (off-board) parts:\n\n	Connex SMPS300REh: Power supply.\n\n	Neutrik NF2D-B-9: RCA jack (white) x3 (Audio inputs)\n	Neutrik NF2D-B-2: RCA jack (red) x3 (Audio inputs)\n\n	Mueller Electric BU-P3770-0 (black) x2 (Speaker post)\n	Mueller Electric BU-P3770-2 (red) x2 (Speaker post)\n\n	PIHER PC16IP04103A (10k potentiometer) (balance control)\n	Omeg PO4S-LIN 100K (100k potentiometer) (Volume control)\n\n	Schurter 4304.6090 (IEC Inlet)\n\n	C&K F-Series (Input selector pushbuttons)"
		(exclude_from_sim no)
		(at 38.1 25.4 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "b04f63d7-dc23-49d3-b1b8-c7b63ca79713")
	)
	(text "Mechanical parts list:\n  1x Wakefield 120-2 (Thermal paste)\n  8x Aavid 4180G (Al2O3 insulators, TO-3P, for output devices, 4 per channel)\n  10x Aavid 4171G (Al2O3 insulators, TO-220, for drivers and bias generator, 5 per channel)\n  18x Bivar SW‑185‑150 (insulating washer for screw holes, M3 screw, needed for all heatsinked transistors)\n  18x M3 flat washer, stainless steel\n  18x M3 spring-lock washer, stainless steel\n  18x M3 nut, stainless steel\n  2x  Noctua NF-A8 ULN (fans)"
		(exclude_from_sim no)
		(at 127 25.4 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "d109d40b-60b4-4fdd-80f8-d4d461cb5a76")
	)
