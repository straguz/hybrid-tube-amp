	(text "LM317/337:"
		(exclude_from_sim no)
		(at 101.6 127 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left top)
		)
		(uuid "095f5c4d-1536-4be2-8360-1a93e7b042bb")
	)
	(text "Switching regulator to generate 6.3V heater bias\nDesigned for Vin = 30V, Vout=6.3V, Iout=660 mA,\nfmin = 80 kHz, Vripple = 300 mV p-p(Max)\n\nCalcs from datasheet (TI datasheet pg 16):\nton/toff = (6.3V+0.49V)/(30V-0.45V-6.3V) = 0.292\nton+toff = 1/f = 1/80k = 12.5us\ntoff = (ton+toff)/(ton/toff + 1) = 9.67 us\nton = (ton+toff)-toff = 2.83 us\nCt = 4e-5*ton = 113pF\nIpk = 2*Iout = 2*0.66 = 1.33 A\nRsc = 0.3/Ipk = 0.3/1.33 = 0.22 Ohm\nLmin = ((Vin-Vsat-Vout)/Ipk)*ton\n     = ((30V-0.45V-6.3V)/1.33A)*2.83us = 49 uH\nCo = Ipk*(ton+toff)/(8*Vripple) = 1.33A*12.5us/(8*0.3V) = 6.9 uF\nVout = -1.25V*(1+R2/R1) = 1.25V*(1+1580/390) = 6.31V\n\nThe chip has built-in current limiting (through the sense resistor)\nNo need for additional inrush limiting."
		(exclude_from_sim no)
		(at 127 31.75 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "40359184-f9be-4e9b-a4d2-a4a30c4ce882")
	)
	(text "Used to step aux 18V supply down to 12V for fans\nFans draw each 50 mA -> regulator Pdiss = 6V*0.1A = 0.6W"
		(exclude_from_sim no)
		(at 209.55 76.2 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "4df566e3-0ca3-46c9-8728-4761600e060e")
	)
	(text "MC34063AP"
		(exclude_from_sim no)
		(at 127 25.4 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left top)
		)
		(uuid "5929b38e-1fff-45f3-a722-c8baa1ddad58")
	)
	(text "LM7812"
