	(text "Power inputs (terminal block)"
		(exclude_from_sim no)
		(at 196.85 95.25 0)
		(effects
			(font
				(size 1.905 1.905)
			)
			(justify left top)
		)
		(uuid "70eeb46a-552b-43bb-bc9f-3c31f1203c7b")
	)
	(text "Used to step aux 18V supply down to 15V.\nInput/output decoupling from datasheet.\nADJ cap included for improved ripple rejection\nProtection diodes included based on schematic\nFeedback resistors calculated as:\n    Vo = Vref*(1+R2/R1) + (I_ADJ*R2)\n    Vo = 1.25V*(1+2700R/240R) + (50 uA * 2700R)\n        = 15.4V"
		(exclude_from_sim no)
		(at 101.6 133.35 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "bdf30566-678f-4356-8f98-438b8ff2be87")
	)
